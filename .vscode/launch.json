{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Api + Worker",
      "configurations": ["BSOFT.Api", "BSOFT.Worker"],
      "preLaunchTask": "build-api",
      "stopAll": true
    }
  ],
  "configurations": [
    {
      "name": "BSOFT.Api",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/src/BSOFT.Api/bin/Debug/net8.0/BSOFT.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/BSOFT.Api",
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_WATCH_SUPPRESS_LAUNCH_BROWSER": "true"
      }
    },
    {
      "name": "BSOFT.Worker",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-worker",
      "program": "${workspaceFolder}/src/BSOFT.Worker/bin/Debug/net8.0/BSOFT.Worker.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/BSOFT.Worker",
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}

# run-qa.ps1.example — Launch BSOFT.Api for LOCAL QA / Functional test runs.
#
# COPY THIS to run-qa.ps1 (which is gitignored), set your DB password, and run it.
#   Copy-Item run-qa.ps1.example run-qa.ps1
#
# How it targets the isolated QA clone (BannariERP_QATest):
#   It launches the API with ASPNETCORE_ENVIRONMENT=qa, so the API loads the COMMITTED
#   src/BSOFT.Api/appsettings.QA.json — whose DefaultConnection + NotificationConnection
#   already point at Database=BannariERP_QATest. The DB name lives in ONE place
#   (appsettings.QA.json), not here, so it can never drift from CI.
#
#   The three DATABASE_* env vars below only fill the {SERVER}/{USER_ID}/{ENC_PASSWORD}
#   placeholders in those connection strings (and in Hangfire/Notification). Forgetting
#   them is what causes the Hangfire "error 53 / network path not found" startup crash.
#
# This mirrors EXACTLY what the deploy-and-test pipeline does on the QA server
# (web.config sets ASPNETCORE_ENVIRONMENT=qa + DATABASE_* from Gitea secrets).
#
# ⚠️  NEVER run the API as Development for QA/Functional tests — appsettings.Development.json
#     points DefaultConnection at the SHARED Database=BannariERP and your tests would
#     read/write the real dev database.

$ErrorActionPreference = 'Stop'
Set-Location $PSScriptRoot   # run from repo root regardless of where it's invoked

# --- Target the committed QA settings (BannariERP_QATest) ---
$env:ASPNETCORE_ENVIRONMENT = 'qa'

# --- Placeholder values for ALL connection strings. Server/User are shared dev infra; ---
# --- the PASSWORD is read from your environment so no secret is committed.             ---
$env:DATABASE_SERVER = '192.168.1.126'
$env:DATABASE_USERID = 'developer'

if (-not $env:DATABASE_PASSWORD) {
    Write-Host "DATABASE_PASSWORD is not set." -ForegroundColor Red
    Write-Host "Set it once for this session, then re-run:" -ForegroundColor Yellow
    Write-Host "    `$env:DATABASE_PASSWORD = '<dev-db-password>'" -ForegroundColor Yellow
    Write-Host "(Or hardcode it in your local, gitignored run-qa.ps1 copy.)" -ForegroundColor DarkGray
    exit 1
}

Write-Host 'Starting BSOFT.Api (ASPNETCORE_ENVIRONMENT=qa) -> BannariERP_QATest on http://localhost:5239' -ForegroundColor Cyan
Write-Host 'Ctrl+C to stop. Run the QA / Functional suite from a SECOND terminal.' -ForegroundColor DarkGray

dotnet run --project src/BSOFT.Api --no-launch-profile --urls 'http://localhost:5239'

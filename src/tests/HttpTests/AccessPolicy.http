# =============================================================================
# MODULE  : UserManagement
# ENTITY  : AccessPolicy
# TABLE   : [AppSecurity].[AccessPolicy] | [AppSecurity].[RoleAccessPolicy]
# =============================================================================
#
# ✅ FULLY AUTOMATED — change only these 3 lines per environment:
#
@baseUrl       = http://localhost:5239
@loginUsername = testsales
@loginPassword = Test@1234

# Fixed — update only if your DB has different IDs
@validRoleId   = 7
@validValueId  = 1

# Unique policy code — $timestamp makes every run distinct
@policyCode       = POLT{{$timestamp}}

# Sentinel values — replaced at request-time by .httpyac.js onRequest hook.
# 11111111 → real createdId after TC17 succeeds
# 22222222 → real roleAssignmentId after TC48 succeeds
@createdId        = 11111111
@roleAssignmentId = 22222222
@token            = PLACEHOLDER


# =============================================================================
# TC-0 — FORCE LOGOUT (AllowAnonymous — no token needed)
# Clears any existing session for loginUsername so TC00 can obtain a fresh token.
# =============================================================================

### TC-0 🔓 Force Logout (clear existing session)
# Expected: 200 OK
POST {{baseUrl}}/api/auth/deactivate-user-sessionByUsername
Content-Type: application/json

{
  "username": "{{loginUsername}}",
  "password": "{{loginPassword}}"
}


# =============================================================================
# TC00 — AUTO LOGIN
# .httpyac.js hook captures data.token → sets {{token}} for all requests below
# =============================================================================

### TC00 🔐 Auto Login
# @name login
# Expected: 200 OK | data.token = JWT string
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{loginUsername}}",
  "password": "{{loginPassword}}"
}


# =============================================================================
# SECTION 5 — CREATE ACCESS POLICY  (runs FIRST — hook captures createdId)
# POST /api/usermanagement/AccessPolicy
# =============================================================================

### TC17 ✅ Create - Happy Path
# @name createPolicy
# Expected : 200 OK | isSuccess=true | message="Access Policy created successfully." | data=<newId>
# Hook captures data → sets {{createdId}} automatically
POST {{baseUrl}}/api/usermanagement/AccessPolicy
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "policyCode": "{{policyCode}}",
  "policyName": "Test Access Policy",
  "entityName": "TestEntity",
  "fieldName": "TestField"
}

### TC18 ❌ Create - No Auth Token
# Expected : 401 Unauthorized
POST {{baseUrl}}/api/usermanagement/AccessPolicy
Content-Type: application/json


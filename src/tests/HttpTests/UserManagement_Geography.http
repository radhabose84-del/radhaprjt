# =============================================================================
# SECTION 4 — DELETE SEQUENCE (reverse FK order: City → State → Country)
# Validates FK-blocked deletes before happy-path deletes
# =============================================================================

### TC61 ❌ Delete Country - Blocked (State linked)
# Expected: 400 | This master is linked with other records. You cannot delete this record.
DELETE {{baseUrl}}/api/Country/{{countryId}}
Authorization: Bearer {{token}}


### TC62 ❌ Delete State - Blocked (City linked)
# Expected: 400 | This master is linked with other records. You cannot delete this record.
DELETE {{baseUrl}}/api/State/{{stateId}}
Authorization: Bearer {{token}}


### TC63 ✅ Delete City - Happy Path (soft delete)
# Expected: 200 OK | isSuccess=true
DELETE {{baseUrl}}/api/City/{{cityId}}
Authorization: Bearer {{token}}


### TC64 ⚠️ Verify City Soft Deleted - GetById returns null
# Expected: 200 OK | data = null (city hidden after soft delete)
GET {{baseUrl}}/api/City/{{cityId}}
Authorization: Bearer {{token}}


### TC65 ✅ Delete State - Happy Path (no cities linked now)
# Expected: 200 OK | isSuccess=true
DELETE {{baseUrl}}/api/State/{{stateId}}
Authorization: Bearer {{token}}


### TC66 ⚠️ Verify State Soft Deleted - GetById returns null
# Expected: 200 OK | data = null
GET {{baseUrl}}/api/State/{{stateId}}
Authorization: Bearer {{token}}


### TC67 ✅ Delete Country - Happy Path (no states linked now)
# Expected: 200 OK | isSuccess=true
DELETE {{baseUrl}}/api/Country/{{countryId}}
Authorization: Bearer {{token}}


### TC68 ⚠️ Verify Country Soft Deleted - GetById returns null
# Expected: 200 OK | data = null
GET {{baseUrl}}/api/Country/{{countryId}}
Authorization: Bearer {{token}}


### TC69 ❌ Delete Country - Non-Existent ID
# Expected: 400 | Country not found.
DELETE {{baseUrl}}/api/Country/999999
Authorization: Bearer {{token}}


### TC70 ❌ Delete Country - No Auth Token
# Expected: 401 Unauthorized
DELETE {{baseUrl}}/api/Country/999999

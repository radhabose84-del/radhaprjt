# =============================================================================
# MODULE  : UserManagement
# ENTITIES: Country → State → City  (FK chain — must run in this order)
# TABLES  : [Location].[Countries] | [Location].[States] | [Location].[Cities]
# =============================================================================
#
# ✅ FULLY AUTOMATED — change only these 3 lines per environment:
#
@baseUrl       = http://localhost:5239
@loginUsername = testsales
@loginPassword = Test@1234

# Unique codes per run (5-char max — C/S/Y prefix + 4 random digits)
@countryCode = C{{$randomInt 1000 9999}}
@stateName   = TestState{{$randomInt 1000 9999}}
@stateCode   = S{{$randomInt 1000 9999}}
@cityName    = TestCity{{$randomInt 1000 9999}}
@cityCode    = Y{{$randomInt 1000 9999}}

# Sentinel values — replaced at request-time by .httpyac.js onRequest hook:
#   11111111 → real countryId  (captured from createCountry response)
#   22222222 → real stateId    (captured from createState response)
#   33333333 → real cityId     (captured from createCity response)
@countryId = 11111111
@stateId   = 22222222
@cityId    = 33333333
@token     = PLACEHOLDER


# =============================================================================
# SETUP — Force logout then login to obtain JWT
# =============================================================================

### TC-0 🔓 Force Logout (clear existing session)
# Expected: 200 OK
POST {{baseUrl}}/api/auth/deactivate-user-sessionByUsername
Content-Type: application/json

{
  "username": "{{loginUsername}}",
  "password": "{{loginPassword}}"
}


### TC00 🔐 Auto Login
# @name login
# Expected: 200 OK | data.token = JWT string
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{loginUsername}}",
  "password": "{{loginPassword}}"
}


# =============================================================================
# SECTION 1 — COUNTRY
# POST   api/usermanagement/Country
# GET    api/usermanagement/Country
# GET    api/usermanagement/Country/{id}
# GET    api/usermanagement/Country/by-name?name=
# PUT    api/usermanagement/Country
# DELETE api/usermanagement/Country/{id}
# =============================================================================

### TC01 ✅ Create Country - Happy Path
# @name createCountry
# Expected: 200 OK | isSuccess=true | data=<newId>
# Hook captures data → sets countryId (slot 0 → 11111111)
POST {{baseUrl}}/api/Country
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "countryCode": "{{countryCode}}",
  "countryName": "TestCountry {{countryCode}}"
}


### TC02 ❌ Create Country - No Auth Token
# Expected: 401 Unauthorized
POST {{baseUrl}}/api/Country
Content-Type: application/json

{
  "countryCode": "{{countryCode}}",
  "countryName": "TestCountry {{countryCode}}"
}


### TC03 ❌ Create Country - Code Empty
# Expected: 400 | CountryCode is required.
POST {{baseUrl}}/api/Country
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "countryCode": "",
  "countryName": "TestCountry {{countryCode}}"
}


### TC04 ❌ Create Country - Name Empty
# Expected: 400 | CountryName is required.
POST {{baseUrl}}/api/Country
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "countryCode": "{{countryCode}}",
  "countryName": ""
}


### TC05 ❌ Create Country - Code Exceeds MaxLength (6 chars, max is 5)
# Expected: 400 | CountryCode cannot be longer than 5 characters.
POST {{baseUrl}}/api/Country
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "countryCode": "ABCDEF",
  "countryName": "TestCountry {{countryCode}}"
}


### TC06 ❌ Create Country - Name Exceeds MaxLength (51 chars, max is 50)
# Expected: 400 | CountryName cannot be longer than 50 characters.
POST {{baseUrl}}/api/Country
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "countryCode": "{{countryCode}}",
  "countryName": "ThisCountryNameIsExactlyFiftyOneCharactersLongXXXXXX"
}


### TC07 ❌ Create Country - Duplicate Code (same as TC01)
# Expected: 400 | CountryCode already exists.
POST {{baseUrl}}/api/Country
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "countryCode": "{{countryCode}}",
  "countryName": "Another Country"
}


### TC08 ✅ GetAll Countries - Happy Path
# Expected: 200 OK | data array with TotalCount
GET {{baseUrl}}/api/Country?PageNumber=1&PageSize=10
Authorization: Bearer {{token}}


### TC09 ❌ GetAll Countries - No Auth Token
# Expected: 401 Unauthorized
GET {{baseUrl}}/api/Country?PageNumber=1&PageSize=10


### TC10 🔍 GetAll Countries - Search by Term
# Expected: 200 OK | data contains only matching records
GET {{baseUrl}}/api/Country?PageNumber=1&PageSize=10&SearchTerm={{countryCode}}
Authorization: Bearer {{token}}


### TC11 ✅ GetById Country - Valid ID
# Expected: 200 OK | data.id = countryId
GET {{baseUrl}}/api/Country/{{countryId}}
Authorization: Bearer {{token}}


### TC12 ❌ GetById Country - No Auth Token
# Expected: 401 Unauthorized
GET {{baseUrl}}/api/Country/{{countryId}}


### TC13 ⚠️ GetById Country - Non-Existent ID
# Expected: 200 OK | data = null (soft behavior)
GET {{baseUrl}}/api/Country/999999
Authorization: Bearer {{token}}


### TC14 ✅ AutoComplete Country - With Term
# Expected: 200 OK | array of matching country lookup items
GET {{baseUrl}}/api/Country/by-name?name={{countryCode}}
Authorization: Bearer {{token}}


### TC15 ❌ AutoComplete Country - No Auth Token
# Expected: 401 Unauthorized
GET {{baseUrl}}/api/Country/by-name?name={{countryCode}}


### TC16 ✅ Update Country - Happy Path
# Expected: 200 OK | isSuccess=true
PUT {{baseUrl}}/api/Country
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "id": {{countryId}},
  "countryCode": "{{countryCode}}",
  "countryName": "Updated Country {{countryCode}}",
  "isActive": 1
}


### TC17 ❌ Update Country - No Auth Token
# Expected: 401 Unauthorized
PUT {{baseUrl}}/api/Country
Content-Type: application/json

{
  "id": {{countryId}},
  "countryCode": "{{countryCode}}",
  "countryName": "Updated Country {{countryCode}}",
  "isActive": 1
}


### TC18 ❌ Update Country - Id = 0
# Expected: 400 | Valid Id is required.
PUT {{baseUrl}}/api/Country
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "id": 0,
  "countryCode": "{{countryCode}}",
  "countryName": "Updated Country",
  "isActive": 1
}


### TC19 ❌ Update Country - Name Empty
# Expected: 400 | CountryName is required.
PUT {{baseUrl}}/api/Country
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "id": {{countryId}},
  "countryCode": "{{countryCode}}",
  "countryName": "",
  "isActive": 1
}


### TC20 ❌ Update Country - IsActive Invalid (not 0 or 1)
# Expected: 400 | IsActive must be either 0 or 1.
PUT {{baseUrl}}/api/Country
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "id": {{countryId}},
  "countryCode": "{{countryCode}}",
  "countryName": "Updated Country {{countryCode}}",
  "isActive": 2
}


